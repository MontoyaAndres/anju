    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-auth": "^1.4.18",
    "hono": "^4.11.9",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@anju/tsconfig": "*",
    "@cloudflare/workers-types": "^4.20260217.0",
    "@types/node": "^25.2.3",
    "esbuild": "^0.27.3",
    "fast-glob": "^3.3.3",
    "typescript": "^5.9.3"
  }
